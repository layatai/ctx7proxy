# Comma-separated Context7 keys. JSON array syntax is also accepted.
CONTEXT7_API_KEYS=ctx7sk-account-one,ctx7sk-account-two

PORT=3000
HOST=127.0.0.1

# Optional bearer token required from proxy clients.
# PROXY_API_KEY=replace-with-a-long-random-value

# Account cooldown after 429/5xx responses (milliseconds).
ACCOUNT_COOLDOWN_MS=60000
# Maximum request body accepted by the proxy (bytes).
MAX_BODY_BYTES=1048576
